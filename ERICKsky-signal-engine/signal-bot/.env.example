# ═══════════════════════════════════════════════════
# ERICKsky Signal Engine - Environment Configuration
# Copy to .env and fill in your actual values
# ═══════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=erickskybot
DB_USER=erickskybot
DB_PASSWORD=

# ─── Redis ─────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ─── Twelve Data API ───────────────────────────────
TWELVE_DATA_API_KEY=869564e2fbb14fa28542f7ca6c104cf1
TWELVE_DATA_BASE_URL=https://api.twelvedata.com

# ─── Telegram ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=992a0bae9ef719bdbd6e3a7118058d79b5e8e62c
TELEGRAM_FREE_CHANNEL=-100xxxxxxxxx
TELEGRAM_PREMIUM_CHANNEL=-100xxxxxxxxx
TELEGRAM_ADMIN_CHAT_ID=Z69JW3

# ─── Trading Configuration ─────────────────────────
TRADING_PAIRS=EURUSD,GBPUSD,USDJPY,XAUUSD
SCAN_INTERVAL_MINUTES=60
MIN_CONSENSUS_SCORE=75
SIGNAL_VALID_MINUTES=30
MAX_SIGNALS_PER_PAIR_PER_DAY=3
RISK_REWARD_RATIO=2.0

# ─── Session Windows (UTC hours) ───────────────────
LONDON_START=7
LONDON_END=16
NEWYORK_START=12
NEWYORK_END=21
ASIAN_START=0
ASIAN_END=9

# ─── Strategy Weights ──────────────────────────────
STRATEGY_WEIGHT_MULTI_TIMEFRAME=25
STRATEGY_WEIGHT_SMART_MONEY=30
STRATEGY_WEIGHT_PRICE_ACTION=25
STRATEGY_WEIGHT_TECHNICAL=20

# ─── Application ───────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
TIMEZONE=UTC
