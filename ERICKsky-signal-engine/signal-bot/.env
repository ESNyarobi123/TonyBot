# ─── Telegram ──────────────────────────────────────
# NOTE: Bot token format must be {bot_id}:{hash} e.g. 7123456789:AAFxxxx
# Get correct token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=7899253114:AAE0Z6vfxXRBQwJ6PIR3tuAY8Tr-asPiZyI
TELEGRAM_FREE_CHANNEL=-100xxxxxxxxx
TELEGRAM_PREMIUM_CHANNEL=-100xxxxxxxxx
# NOTE: TELEGRAM_ADMIN_CHAT_ID must be a numeric ID (e.g. 123456789)
# Get yours by messaging @userinfobot on Telegram
TELEGRAM_ADMIN_CHAT_ID=8090015052
# Proxy to bypass ISP block on api.telegram.org (leave empty if not needed)
# Format: socks5://user:pass@host:port  OR  http://user:pass@host:port
TELEGRAM_PROXY_URL=

# ─── Trading Configuration ─────────────────────────
